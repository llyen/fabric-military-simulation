# Environment variables for the SENTINEL app (Vite).
#
# Most VITE_* values (RAYFIN_API_URL, PUBLISHABLE_KEY, FABRIC_*) are generated
# into .env.local automatically by `rayfin env` — do NOT set those here.
#
# This file documents extra, hand-set flags. Copy what you need into a local
# `.env` (root, git-ignored, NOT overwritten by rayfin) and rebuild/redeploy.

# --- Fabric Data Agent ("Ask AI" HUD panel) --------------------------------
# URL of the read-only Data Agent proxy (see proxy/data-agent/). When empty the
# Ask AI panel stays inactive and shows a hint. Set this, then `npm run rayfin:up`.
# Local example:  http://localhost:7071/
# Deployed:       https://<your-func-app>.azurewebsites.net/api/ask
VITE_DATA_AGENT_URL=
